procedure TfrmMain.btnOpSaveClick(Sender: TObject);
var
  Q: TFDQuery;
begin
  SetOpError('');
  if Trim(edtOpNaziv.Text) = '' then begin SetOpError('Naziv je obavezan.'); Exit; end;
  if Trim(cmbOpTip.Text)   = '' then begin SetOpError('Tip je obavezan.');   Exit; end;

  Q := TFDQuery.Create(nil);
  try
    Q.Connection := dmData.Conn;
    if FOpCurrentID < 0 then
      Q.SQL.Text :=
        'INSERT INTO EQUIPMENT_CENTER ' +
        '(EQ_NAME, EQ_TYPE, EQ_MODEL, EQ_SERIAL, EQ_STATUS, EQ_PURCHASE_DATE, EQ_NOTES) ' +
        'VALUES (:NAME, :TYPE, :MODEL, :SERIAL, :STATUS, :PDATE, :NOTES)'
    else
    begin
      Q.SQL.Text :=
        'UPDATE EQUIPMENT_CENTER SET EQ_NAME=:NAME, EQ_TYPE=:TYPE, ' +
        'EQ_MODEL=:MODEL, EQ_SERIAL=:SERIAL, EQ_STATUS=:STATUS, ' +
        'EQ_PURCHASE_DATE=:PDATE, EQ_NOTES=:NOTES WHERE EQ_ID=:ID';
      Q.ParamByName('ID').AsInteger := FOpCurrentID;
    end;

    Q.ParamByName('NAME').AsString   := Trim(edtOpNaziv.Text);
    Q.ParamByName('TYPE').AsString   := Trim(cmbOpTip.Text);
    Q.ParamByName('MODEL').AsString  := Trim(edtOpModel.Text);
    Q.ParamByName('SERIAL').AsString := Trim(edtOpSerial.Text);
    Q.ParamByName('STATUS').AsString := Trim(cmbOpStatus.Text);
    Q.ParamByName('NOTES').AsString  := Trim(memoOpNap.Text);

    if Trim(edtOpDatum.Text) <> '' then
      Q.ParamByName('PDATE').AsDate := StrToDateDef(edtOpDatum.Text, Date)
    else
      Q.ParamByName('PDATE').Clear;

    Q.ExecSQL;
    dmData.CommitWork;
    LoadOprema;
    HideOpDetail;
    RefreshDashboard;
  except
    on E: Exception do
      SetOpError('Greska: ' + E.Message);
  end;
  Q.Free;
end;

