procedure TfrmMain.LoadOprema(const AFilter: string);
var
  Q   : TFDQuery;
  SQL : string;
  Item: TListViewItem;
begin
  lstOprema.Items.Clear;
  if not dmData.IsConnected then Exit;

  SQL := 'SELECT EQ_ID, EQ_NAME, EQ_TYPE, EQ_STATUS FROM EQUIPMENT_CENTER ';
  if Trim(AFilter) <> '' then
    SQL := SQL +
      'WHERE UPPER(EQ_NAME) CONTAINING UPPER(''' + AFilter + ''') ' +
      'OR UPPER(EQ_TYPE) CONTAINING UPPER(''' + AFilter + ''') ';
  SQL := SQL + 'ORDER BY EQ_NAME';

  Q := TFDQuery.Create(nil);
  try
    Q.Connection := dmData.Conn;
    Q.SQL.Text   := SQL;
    Q.Open;
    while not Q.Eof do
    begin
      Item        := lstOprema.Items.Add;
      Item.Text   := Q.FieldByName('EQ_NAME').AsString;
      Item.Detail := Q.FieldByName('EQ_TYPE').AsString + '  ·  ' +
                     Q.FieldByName('EQ_STATUS').AsString;
      Item.Tag    := Q.FieldByName('EQ_ID').AsInteger;
      Q.Next;
    end;
  finally
    Q.Free;
  end;
end;

