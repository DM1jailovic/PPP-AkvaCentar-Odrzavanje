  { DataModule je vec otvorio konekciju u svom Create — odmah ucitavamo }
  if dmData.IsConnected then
  begin
    tcMain.ActiveTab := tiDashboard;
    RefreshDashboard;
    LoadOprema;
    LoadNalozi;
  end
  else
    ShowMessage('Baza nije dostupna. Proverite Baza\ folder i Firebird DLL-ove.');
end;

