procedure TfrmMain.LoadNalozi(const AStatusFilter: string);
var
  Q   : TFDQuery;
  SQL : string;
  Item: TListViewItem;
begin
  lstNalozi.Items.Clear;
  if not dmData.IsConnected then Exit;

  SQL :=
    'SELECT M.ML_ID, M.ML_DATE, M.ML_TYPE, M.ML_STATUS, ' +
    '       E.EQ_NAME, M.ML_DESCRIPTION ' +
    'FROM MAINTENANCE_LOG M ' +
    'JOIN EQUIPMENT_CENTER E ON E.EQ_ID = M.ML_EQ_ID ';

  if (Trim(AStatusFilter) <> '') and (AStatusFilter <> 'Svi statusi') then
    SQL := SQL + 'WHERE M.ML_STATUS = ''' + AStatusFilter + ''' ';

  SQL := SQL + 'ORDER BY M.ML_DATE DESC';

  Q := TFDQuery.Create(nil);
  try
    Q.Connection := dmData.Conn;
    Q.SQL.Text   := SQL;
    Q.Open;
    while not Q.Eof do
    begin
      Item        := lstNalozi.Items.Add;
      Item.Text   := Q.FieldByName('EQ_NAME').AsString + '  —  ' +
                     Q.FieldByName('ML_TYPE').AsString;
      Item.Detail := Q.FieldByName('ML_DATE').AsString + '  [' +
                     Q.FieldByName('ML_STATUS').AsString + ']';
      Item.Tag    := Q.FieldByName('ML_ID').AsInteger;
      Q.Next;
    end;
  finally
    Q.Free;
  end;
end;

