procedure TfrmMain.LoadEquipCombo;
var
  Q: TFDQuery;
  N: Integer;
begin
  cmbNalOprema.Items.Clear;
  SetLength(FEquipIDs, 0);
  N := 0;

  Q := TFDQuery.Create(nil);
  try
    Q.Connection := dmData.Conn;
    Q.SQL.Text   :=
      'SELECT EQ_ID, EQ_NAME, EQ_TYPE FROM EQUIPMENT_CENTER ORDER BY EQ_NAME';
    Q.Open;
    while not Q.Eof do
    begin
      cmbNalOprema.Items.Add(
        Q.FieldByName('EQ_NAME').AsString + ' (' +
        Q.FieldByName('EQ_TYPE').AsString + ')');
      SetLength(FEquipIDs, N + 1);
      FEquipIDs[N] := Q.FieldByName('EQ_ID').AsInteger;
      Inc(N);
      Q.Next;
    end;
  finally
    Q.Free;
  end;
end;

procedure TfrmMain.ShowNalDetail(ANew: Boolean);
begin
  FNalIsNew := ANew;
  LoadEquipCombo;
  pnlNalDetail.Visible := True;

  if ANew then
  begin
    lblNalFormTitle.Text   := 'Novi Nalog Odrzavanja';
    cmbNalOprema.ItemIndex := -1;
    edtNalDatum.Text       := FormatDateTime('YYYY-MM-DD', Now);
    cmbNalTip.Text         := 'Rutinsko';
    cmbNalStatus.Text      := 'Na cekanju';
    edtNalTrosak.Text      := '0';
    edtNalIzvrsio.Text     := '';
    edtNalSledeci.Text     := '';
    memoNalOpis.Text       := '';
    memoNalNap.Text        := '';
    FNalCurrentID          := -1;
  end
  else
  begin
    lblNalFormTitle.Text := 'Izmena Naloga';
    FNalCurrentID := NalSelectedID;
    PopulateNalDetail(FNalCurrentID);
  end;
  SetNalError('');
end;

procedure TfrmMain.HideNalDetail;
begin
  pnlNalDetail.Visible := False;
end;

procedure TfrmMain.PopulateNalDetail(AID: Integer);
var
  Q   : TFDQuery;
  EqID: Integer;
  I   : Integer;
begin
  Q := TFDQuery.Create(nil);
  try
    Q.Connection := dmData.Conn;
    Q.SQL.Text   := 'SELECT * FROM MAINTENANCE_LOG WHERE ML_ID = :ID';
    Q.ParamByName('ID').AsInteger := AID;
    Q.Open;
    if not Q.IsEmpty then
    begin
      EqID := Q.FieldByName('ML_EQ_ID').AsInteger;
      cmbNalOprema.ItemIndex := -1;
      for I := 0 to High(FEquipIDs) do
        if FEquipIDs[I] = EqID then begin cmbNalOprema.ItemIndex := I; Break; end;

      edtNalDatum.Text   := Q.FieldByName('ML_DATE').AsString;
      cmbNalTip.Text     := Q.FieldByName('ML_TYPE').AsString;
      cmbNalStatus.Text  := Q.FieldByName('ML_STATUS').AsString;
      edtNalIzvrsio.Text := Q.FieldByName('ML_PERFORMED_BY').AsString;
      edtNalTrosak.Text  := Q.FieldByName('ML_COST').AsString;
      edtNalSledeci.Text := Q.FieldByName('ML_NEXT_DUE').AsString;
      memoNalOpis.Text   := Q.FieldByName('ML_DESCRIPTION').AsString;
      memoNalNap.Text    := Q.FieldByName('ML_NOTES').AsString;
    end;
  finally
    Q.Free;
  end;
end;

procedure TfrmMain.btnNalSaveClick(Sender: TObject);
var
  Q    : TFDQuery;
  EqIdx: Integer;
begin
  SetNalError('');
  EqIdx := cmbNalOprema.ItemIndex;
  if EqIdx < 0         then begin SetNalError('Izaberite opremu.');       Exit; end;
  if Trim(edtNalDatum.Text) = '' then begin SetNalError('Datum je obavezan.'); Exit; end;
  if Trim(memoNalOpis.Text) = '' then begin SetNalError('Opis je obavezan.');  Exit; end;

  Q := TFDQuery.Create(nil);
  try
    Q.Connection := dmData.Conn;
    if FNalCurrentID < 0 then
      Q.SQL.Text :=
        'INSERT INTO MAINTENANCE_LOG ' +
        '(ML_EQ_ID, ML_DATE, ML_TYPE, ML_DESCRIPTION, ML_PERFORMED_BY, ' +
        ' ML_COST, ML_STATUS, ML_NEXT_DUE, ML_NOTES) ' +
        'VALUES (:EQID,:MDATE,:TYPE,:DESC,:PERF,:COST,:STATUS,:NEXTDUE,:NOTES)'
    else
    begin
      Q.SQL.Text :=
        'UPDATE MAINTENANCE_LOG SET ' +
        'ML_EQ_ID=:EQID, ML_DATE=:MDATE, ML_TYPE=:TYPE, ' +
        'ML_DESCRIPTION=:DESC, ML_PERFORMED_BY=:PERF, ' +
        'ML_COST=:COST, ML_STATUS=:STATUS, ML_NEXT_DUE=:NEXTDUE, ML_NOTES=:NOTES ' +
        'WHERE ML_ID=:ID';
      Q.ParamByName('ID').AsInteger := FNalCurrentID;
    end;

    Q.ParamByName('EQID').AsInteger  := FEquipIDs[EqIdx];
    Q.ParamByName('MDATE').AsDate    := StrToDateDef(edtNalDatum.Text, Date);
    Q.ParamByName('TYPE').AsString   := Trim(cmbNalTip.Text);
    Q.ParamByName('DESC').AsString   := Trim(memoNalOpis.Text);
    Q.ParamByName('PERF').AsString   := Trim(edtNalIzvrsio.Text);
    Q.ParamByName('COST').AsFloat    := StrToFloatDef(edtNalTrosak.Text, 0);
    Q.ParamByName('STATUS').AsString := Trim(cmbNalStatus.Text);
    Q.ParamByName('NOTES').AsString  := Trim(memoNalNap.Text);

    if Trim(edtNalSledeci.Text) <> '' then
      Q.ParamByName('NEXTDUE').AsDate := StrToDateDef(edtNalSledeci.Text, Date)
    else
      Q.ParamByName('NEXTDUE').Clear;

    Q.ExecSQL;
    dmData.CommitWork;
    LoadNalozi(cmbNalFilter.Text);
    HideNalDetail;
    RefreshDashboard;
  except
    on E: Exception do
      SetNalError('Greska: ' + E.Message);
  end;
  Q.Free;
end;

